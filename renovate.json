{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>MarcelRoozekrans/renovate-config"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "groupName": "vscode packages",
      "matchPackagePatterns": ["^@vscode/", "^@types/vscode$"]
    },
    {
      "groupName": "testing",
      "matchPackagePatterns": ["mocha", "sinon", "@types/mocha", "@types/sinon"]
    },
    {
      "groupName": "commitlint",
      "matchPackagePatterns": ["^@commitlint/", "^commitlint"]
    }
  ]
}
